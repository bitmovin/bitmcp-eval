{
    "compilerOptions": {
        "target": "es2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "declaration": true,
        "outDir": "./dist",
        "rootDir": ".",
        "allowJs": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",

    },
    "include": ["source/*.ts", "source/*.tsx", "source/*.js"],
    "exclude": ["dist"],

}